<launch>

  <!-- Robot description from your MoveIt xacro -->
  <param name="robot_description"
         value="$(command 'xacro $(find-pkg-share robot_arm_moveit_config)/config/robot_arm.urdf.xacro')" />

  <!-- Robot state publisher -->
  <node pkg="robot_state_publisher" exec="robot_state_publisher"
        name="robot_state_publisher" output="screen">
    <param name="use_sim_time" value="true"/>
  </node>

  <!-- Spawn robot into Gazebo -->
  <node pkg="ros_gz_sim" exec="create"
        name="spawn_robot"
        output="screen"
        args="-topic /robot_description"/>

  <!-- Joint state broadcaster (needed for TF stability later) -->
  <node pkg="controller_manager" exec="spawner"
        args="joint_state_broadcaster"
        output="screen"/>

  <!-- RViz -->
  <node pkg="rviz2" exec="rviz2" name="rviz2" output="screen">
    <param name="use_sim_time" value="true"/>
  </node>

</launch>
