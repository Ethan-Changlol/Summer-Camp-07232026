<launch>

  <!-- Gazebo Sim Server + World -->
  <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
    <arg name="gz_args" value="$(find-pkg-share robot_arm_gazebo)/worlds/empty.world"/>
    <arg name="on_exit_shutdown" value="True"/>
  </include>

  <!-- Gazebo Client (GUI) - VirtualBox safe -->
  <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
    <arg name="gz_args" value="-g --render-engine ogre"/>
    <arg name="on_exit_shutdown" value="True"/>
  </include>

  <!-- ROS <-> Gazebo bridge (CLOCK ONLY for now) -->
  <node pkg="ros_gz_bridge" exec="parameter_bridge" name="bridge" output="screen"
        args="/clock@rosgraph_msgs/msg/Clock[gz.msgs.Clock]"/>

</launch>
