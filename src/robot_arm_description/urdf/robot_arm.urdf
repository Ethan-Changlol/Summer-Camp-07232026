<?xml version="1.0"?>
<robot name="robot_arm">

  <!-- MATERIALS -->
  <material name="white"><color rgba="1 1 1 1"/></material>
  <material name="red"><color rgba="1 0 0 1"/></material>
  <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>
  <material name="yellow"><color rgba="1 1 0 1"/></material>
  <material name="blue"><color rgba="0 0 1 1"/></material>

  <!-- BASE -->
  <link name="base_link">

    <visual>
      <geometry>
        <box size="0.3 0.3 0.05"/>
      </geometry>
      <material name="blue"/>
    </visual>

    <collision>
      <geometry>
        <box size="0.3 0.3 0.05"/>
      </geometry>
    </collision>

  </link>

  <link name="base">

    <visual>
      <origin xyz="0 0 0.05"/>
      <geometry>
        <box size="0.3 0.3 0.3"/>
      </geometry>
      <material name="blue"/>
    </visual>

    <collision>
      <origin xyz="0 0 0.05"/>
      <geometry>
        <box size="0.3 0.3 0.3"/>
      </geometry>
    </collision>

  </link>

  <joint name="base_joint" type="revolute">
    <parent link="base_link"/>
    <child link="base"/>
    <origin xyz="0 0 0.15"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1" upper="3.14" effort="-3.14" velocity="1"/>
  </joint>

  <!-- LINK1 -->
  <link name="link1">

    <visual>
      <origin xyz="0 0 0.15"/>
      <geometry>
        <box size="0.1 0.1 0.3"/>
      </geometry>
      <material name="white"/>
    </visual>

    <collision>
      <origin xyz="0 0 0.15"/>
      <geometry>
        <box size="0.1 0.1 0.3"/>
      </geometry>
    </collision>

  </link>

  <joint name="joint1" type="revolute">
    <parent link="base"/>
    <child link="link1"/>
    <origin xyz="0 0 0.15"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1" upper="1" effort="1" velocity="1"/>
  </joint>

  <!-- LINK2 -->
  <link name="link2">

    <visual>
      <origin xyz="0 0 0.025"/>
      <geometry>
        <box size="0.15 0.15 0.05"/>
      </geometry>
      <material name="blue"/>
    </visual>

    <collision>
      <origin xyz="0 0 0.025"/>
      <geometry>
        <box size="0.15 0.15 0.05"/>
      </geometry>
    </collision>

  </link>

  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0.3"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="1" velocity="1"/>
  </joint>

  <!-- LINK3 -->
  <link name="link3">

    <visual>
      <origin xyz="0 0 0.15"/>
      <geometry>
        <box size="0.1 0.1 0.3"/>
      </geometry>
      <material name="red"/>
    </visual>

    <collision>
      <origin xyz="0 0 0.15"/>
      <geometry>
        <box size="0.1 0.1 0.3"/>
      </geometry>
    </collision>

  </link>

  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 0 0.05"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.5" upper="1.5" effort="1" velocity="1"/>
  </joint>

  <!-- GRIPPER POLE -->
  <link name="gripper_pole_link">

    <visual>
      <origin xyz="0 0 -0.3"/>
      <geometry>
        <box size="0.05 0.05 0.4"/>
      </geometry>
      <material name="gray"/>
    </visual>

    <collision>
      <origin xyz="0 0 -0.3"/>
      <geometry>
        <box size="0.05 0.05 0.4"/>
      </geometry>
    </collision>

  </link>

  <joint name="gripper_extension" type="prismatic">
    <parent link="link3"/>
    <child link="gripper_pole_link"/>
    <origin xyz="0 0 0.5"/>
    <axis xyz="0 0 1"/>
    <limit lower="0" upper="0.3" effort="1000" velocity="0.5"/>
  </joint>

  <!-- LINK4 -->
  <link name="link4_link">

    <visual>
      <origin xyz="0 0 -0.4"/>
      <geometry>
        <box size="0.1 0.2 0.05"/>
      </geometry>
      <material name="blue"/>
    </visual>

    <collision>
      <origin xyz="0 0 -0.4"/>
      <geometry>
        <box size="0.1 0.2 0.05"/>
      </geometry>
    </collision>

  </link>

  <joint name="link4_joint" type="revolute">
    <parent link="gripper_pole_link"/>
    <child link="link4_link"/>
    <origin xyz="0 0 0.3"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="1" velocity="1"/>
  </joint>

  <!-- GRIPPERS -->
  <link name="left_gripper">
    <visual>
      <origin xyz="0 0.075 -0.325"/>
      <geometry><box size="0.1 0.02 0.1"/></geometry>
      <material name="yellow"/>
    </visual>
    <collision>
      <origin xyz="0 0.075 -0.325"/>
      <geometry><box size="0.1 0.02 0.1"/></geometry>
    </collision>
  </link>

  <link name="right_gripper">
    <visual>
      <origin xyz="0 -0.075 -0.325"/>
      <geometry><box size="0.1 0.02 0.1"/></geometry>
      <material name="yellow"/>
    </visual>
    <collision>
      <origin xyz="0 -0.075 -0.325"/>
      <geometry><box size="0.1 0.02 0.1"/></geometry>
    </collision>
  </link>

  <joint name="left_gripper_joint" type="prismatic">
    <parent link="link4_link"/>
    <child link="left_gripper"/>
    <origin xyz="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.065" upper="0" effort="1000" velocity="0.5"/>
  </joint>

  <joint name="right_gripper_joint" type="prismatic">
    <parent link="link4_link"/>
    <child link="right_gripper"/>
    <origin xyz="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-0.065" upper="0" effort="1000" velocity="0.5"/>
  </joint>

</robot>